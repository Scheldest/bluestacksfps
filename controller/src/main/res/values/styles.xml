<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 13 Ancient/Aesthetic Theme -->
    <style name="Theme.DexAdmin" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/surface</item>

        <!-- Material 3 Palette -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <item name="colorPrimaryContainer">@color/primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/onPrimaryContainer</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/onSecondary</item>
        <item name="colorSecondaryContainer">@color/secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/onSecondaryContainer</item>

        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/onSurface</item>
        <item name="colorSurfaceVariant">@color/surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/onSurfaceVariant</item>

        <item name="android:textColorPrimary">@color/onSurface</item>
        <item name="android:textColorSecondary">@color/onSurfaceVariant</item>
        <item name="colorError">@color/error</item>
    </style>

    <style name="CustomTabText" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="AncientButton" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/surfaceVariant</item>
        <item name="android:textColor">@color/onSurfaceVariant</item>
        <item name="iconTint">@color/onSurfaceVariant</item>
        <item name="cornerRadius">20dp</item>
    </style>
</resources>
